{
  "DatabaseProvider": "SqliteInMemory",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=CleanTemplateInMemory;Mode=Memory;Cache=Shared",
    "ReadConnection": "Data Source=CleanTemplateInMemory;Mode=Memory;Cache=Shared"
  },
  "ForwardedHeaders": {
    "KnownProxies": [ "127.0.0.1", "::1" ],
    "KnownNetworks": []
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:5173",
      "https://localhost:5173"
    ]
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 240,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Policies": {
      "auth.login": {
        "PermitLimit": 10,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "auth.refresh": {
        "PermitLimit": 30,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "auth.logout": {
        "PermitLimit": 40,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "CleanTemplate.Host",
    "ServiceVersion": "1.0.0-dev",
    "Otlp": {
      "Endpoint": "http://localhost:4317",
      "Protocol": "grpc"
    },
    "Traces": {
      "Enabled": true,
      "SamplingRatio": 1.0
    },
    "Metrics": {
      "Enabled": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore.Hosting": "Information",
        "System": "Information"
      }
    }
  },
  "Auth": {
    "Schemes": {
      "LocalJwt": {
        "SigningKey": "development-signing-key-not-for-production-123456",
        "AccessTokenMinutes": 15,
        "RefreshTokenDays": 7
      }
    },
    "Provisioning": {
      "Enabled": false,
      "Admin": {
        "Emails": [ "admin@local.template" ],
        "Domains": [ "local.template" ],
        "Groups": [],
        "Roles": [ "Admin" ]
      }
    },
    "RefreshTokenCleanup": {
      "Enabled": true,
      "IntervalMinutes": 15,
      "RevokedRetentionDays": 2
    }
  },
  "IdentitySeed": {
    "AdminEmail": "admin@local.template",
    "AdminPassword": "Secret123!"
  }
}
