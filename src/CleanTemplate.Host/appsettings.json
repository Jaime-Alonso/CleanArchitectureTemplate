{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting": "Warning",
        "Microsoft.AspNetCore.Mvc": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithCorrelationId" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=cleantemplate;Username=postgres;Password=__SET_VIA_USER_SECRETS__",
    "DapperConnection": "Host=localhost;Database=cleantemplate;Username=postgres;Password=__SET_VIA_USER_SECRETS__"
  },
  "ForwardedHeaders": {
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 120,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Policies": {
      "auth.login": {
        "PermitLimit": 5,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "auth.refresh": {
        "PermitLimit": 20,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "auth.logout": {
        "PermitLimit": 30,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    }
  },
  "OpenTelemetry": {
    "ServiceName": "CleanTemplate.Host",
    "ServiceVersion": "1.0.0",
    "Otlp": {
      "Endpoint": "http://localhost:4317",
      "Protocol": "grpc"
    },
    "Traces": {
      "Enabled": true,
      "SamplingRatio": 0.2
    },
    "Metrics": {
      "Enabled": true
    }
  },
  "Auth": {
    "Schemes": {
      "LocalJwt": {
        "Enabled": true,
        "Issuer": "CleanTemplate.Local",
        "Audience": "CleanTemplate.Api",
        "SigningKey": "",
        "ActiveSigningKeyId": "v1",
        "AccessTokenMinutes": 30,
        "RefreshTokenDays": 14
      },
      "Oidc": {
        "Enabled": false,
        "Provider": "EntraId",
        "Authority": "https://login.microsoftonline.com/<tenantId>/v2.0",
        "Audience": "api://<clientId>",
        "Claims": {
          "Email": "email",
          "Name": "name",
          "Subject": "sub",
          "Groups": "groups",
          "Roles": "roles",
          "TenantId": "tid"
        }
      }
    },
    "Provisioning": {
      "Enabled": false,
      "DefaultRole": "User",
      "Admin": {
        "Emails": [ "admin@contoso.com" ],
        "Domains": [ "contoso.com" ],
        "Groups": [ "00000000-0000-0000-0000-000000000000" ],
        "Roles": [ "Admin" ]
      },
      "User": {
        "Groups": [],
        "Roles": [ "User" ]
      }
    },
    "RefreshTokenCleanup": {
      "Enabled": true,
      "IntervalMinutes": 60,
      "RevokedRetentionDays": 7
    }
  },
  "IdentitySeed": {
    "AdminEmail": "admin@local.template",
    "AdminPassword": "__SET_VIA_USER_SECRETS_ADMIN_PASSWORD__"
  },
  "AllowedHosts": "*"
}
